# ── Application ─────────────────────────────────────────────────────────────
# OpenAI API key (required for LLM-powered claim extraction and verdict scoring)
OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Transcript ───────────────────────────────────────────────────────────────
# Whisper model size for audio transcription fallback: tiny, base, small, medium, large
# WHISPER_MODEL=base

# ── Claim extraction ─────────────────────────────────────────────────────────
# Maximum number of claims to extract per video (default: 10)
# MAX_CLAIMS=10

# ── Research ─────────────────────────────────────────────────────────────────
# Number of web search results to fetch per claim (default: 5)
# RESEARCH_MAX_RESULTS=5
